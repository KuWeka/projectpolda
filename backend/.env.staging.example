# ===== Staging Environment =====
NODE_ENV=production
PORT=3001

# ===== CORS =====
CORS_ORIGIN=https://staging.helpdesk.example.com

# ===== Database =====
DB_HOST=mysql
DB_PORT=3306
DB_NAME=helpdesk
DB_USER=helpdesk_user
DB_PASSWORD=helpdesk_pass
MYSQL_ROOT_PASSWORD=change_this_root_password

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===== Auth =====
JWT_SECRET=replace_with_very_long_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_very_long_refresh_secret_min_32_chars
JWT_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# ===== Logging =====
LOG_LEVEL=info

# ===== Upload =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,docx,xlsx

# ===== Socket =====
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=5000
