# ===== Server Configuration =====
NODE_ENV=development
PORT=3001
APP_NAME=Helpdesk IT API
APP_VERSION=1.0.0

# ===== Database Configuration =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=helpdesk_user
DB_PASSWORD=helpdesk_pass
DB_NAME=helpdesk
MYSQL_ROOT_PASSWORD=rootpassword

# ===== Redis Configuration =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ===== JWT Configuration =====
# IMPORTANT: JWT_SECRET MUST be set and at least 32 characters for production
# Generate a secure random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d

# ===== Logging Configuration =====
LOG_LEVEL=info

# ===== CORS Configuration =====
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===== File Upload Configuration =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,docx,xlsx

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== Session Configuration =====
SESSION_SECRET=your_session_secret_key

# ===== Socket.IO Configuration =====
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=5000

# ===== Optional Integrations =====
# Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=no-reply@helpdesk.com

# WhatsApp Integration (for technician notifications)
# WHATSAPP_API_KEY=your_api_key
# WHATSAPP_API_URL=https://api.whatsapp.com
