{
  "name": "helpdesk-backend",
  "version": "1.0.0",
  "description": "IT Helpdesk backend with MySQL and Express",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.config.integration.js",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "db:setup": "node scripts/setup-db.js",
    "db:migrate": "node scripts/migrate.js",
    "db:backup": "node scripts/backup-db.js",
    "db:restore": "bash scripts/restore-db.sh",
    "cache:clear": "node scripts/cache-clear.js",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:sbom": "node scripts/generate-sbom-lite.js",
    "phase7:readiness": "node scripts/supply-chain-readiness.js",
    "health:check": "curl -s http://localhost:3001/api/health/live | jq",
    "health:metrics": "curl -s http://localhost:3001/api/health/metrics",
    "release:readiness": "node scripts/release-readiness.js",
    "smoke:test": "node scripts/smoke-test.js",
    "ops:synthetic": "node scripts/synthetic-check.js",
    "load:test": "node scripts/load-test.js",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "rollback:staging": "bash scripts/rollback-staging.sh",
    "docker:build": "docker build -t helpdesk-api:latest .",
    "docker:run": "docker run -p 3001:3001 --env-file .env helpdesk-api:latest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
}
