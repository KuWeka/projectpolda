# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=3001
APP_NAME=Helpdesk IT API
APP_VERSION=1.0.0

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_PASSWORD=root
DB_NAME=helpdesk_db
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# ===== REDIS =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ===== JWT CONFIGURATION =====
# ⚠️ TEMPORARY KEYS FOR TESTING ONLY (Replace in production!)
# Access Token: Short-lived (1 hour)
JWT_SECRET=dev_access_token_secret_key_minimum_32_characters_long_v1
JWT_EXPIRES=1h

# Refresh Token: Long-lived (7 days)
JWT_REFRESH_SECRET=dev_refresh_token_secret_key_minimum_32_characters_long_v1
JWT_REFRESH_EXPIRES=7d

# ===== SESSION =====
SESSION_SECRET=dev_session_secret_key_minimum_32_characters_long_v1

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ===== LOGGING =====
LOG_LEVEL=info

# ===== FILE UPLOAD =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,docx,xlsx

# ===== RATE LIMIT =====
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== SOCKET =====
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=5000

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:3000
